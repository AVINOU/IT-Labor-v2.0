\chapter{KI-gestützte Sicherheit und Anomalieerkennung}

\section{Machine Learning für Anomalieerkennung}

\subsection{IsolationForest -- Netzwerk-Anomalieerkennung}

\begin{lstlisting}[language=python, caption=ML Anomalieerkennung mit IsolationForest]
import pandas as pd
import numpy as np
from sklearn.ensemble import IsolationForest
from sklearn.preprocessing import StandardScaler
import json

# Zeek-Logs einlesen
logs = []
with open('/opt/zeek/logs/current/conn.log', 'r') as f:
    for line in f:
        if not line.startswith('#'):
            logs.append(json.loads(line))

df = pd.DataFrame(logs)

# Features extrahieren
features = df[['duration', 'orig_bytes', 'resp_bytes',
                'orig_pkts', 'resp_pkts']].fillna(0)

# Normalisieren
scaler = StandardScaler()
X = scaler.fit_transform(features)

# IsolationForest trainieren
model = IsolationForest(
    n_estimators=100,
    contamination=0.01,
    random_state=42
)
df['anomaly'] = model.fit_predict(X)

# Anomalien ausgeben
anomalies = df[df['anomaly'] == -1]
print(f"Gefundene Anomalien: {len(anomalies)}")
print(anomalies[['id.orig_h', 'id.resp_h', 'proto',
                  'orig_bytes', 'resp_bytes']].head(20))
\end{lstlisting}

